# PrismMTR - Local Development Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# 
# HOW TO USE:
# 1. Copy this file to `local-keys.env` (this is gitignored)
# 2. Fill in YOUR actual values from the respective platforms
# 3. Run `netlify dev` to start the local dev server with these secrets
#
# SECURITY WARNING:
# - NEVER commit local-keys.env to git
# - Run `npm run remove-local-keys` before sharing your code
# - These are YOUR personal development keys
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# DISCORD OAUTH
# Get these from: https://discord.com/developers/applications
# Add Redirect URI: http://127.0.0.1:5500/ AND http://localhost:8888/
# ───────────────────────────────────────────────────────────────────────────
# DISCORD OAUTH
# Get these from: https://discord.com/developers/applications
# Add Redirect URI: http://127.0.0.1:5500/ AND http://localhost:8888/
# ───────────────────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET_HERE

# ───────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# Get these from: https://console.cloud.google.com/apis/credentials
# Add Redirect URI: http://127.0.0.1:5500/ AND http://localhost:8888/
# ───────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ───────────────────────────────────────────────────────────────────────────
# GITHUB OAUTH (Optional)
# Get these from: https://github.com/settings/developers
# Add Callback URL: http://127.0.0.1:5500/ AND http://localhost:8888/
# ───────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE

