# Local Postgres example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prismmtr"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/prismmtr"
#
# Supabase production example:
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prismmtr"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/prismmtr"

# Auth.js / NextAuth secret support.
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-the-same-long-random-secret"

# Local app URLs. Set both to keep local dev and hosted callbacks predictable.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Netlify and proxy-friendly host trust.
AUTH_TRUST_HOST="true"

# Discord OAuth
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
